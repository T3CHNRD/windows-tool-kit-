<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="T3CHNRD'S Windows Tool Kit"
    Language="1033"
    Version="1.0.0"
    Manufacturer="Personal Toolkit"
    UpgradeCode="F3C30DC1-8962-451B-B811-5285D0EA2DB6">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="T3CHNRD'S Windows Tool Kit" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="T3CHNRD'S Windows Tool Kit" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <Feature Id="MainFeature" Title="T3CHNRD'S Windows Tool Kit" Level="1">
      <ComponentGroupRef Id="CG_MaintToolkit" />
      <ComponentRef Id="ShortcutComponent" />
    </Feature>

    <UIRef Id="WixUI_Minimal" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <Icon Id="ToolkitIcon" SourceFile="$(var.SourceDir)\T3CHNRD'S Windows Tool Kit.exe" />
    <Property Id="ARPPRODUCTICON" Value="ToolkitIcon" />

    <Component Id="ShortcutComponent" Guid="4B58A5F1-419A-43E7-A9D1-5E0E05963C30" Directory="INSTALLFOLDER">
      <Shortcut
        Id="StartMenuShortcut"
        Directory="ProgramMenuDir"
        Name="T3CHNRD'S Windows Tool Kit"
        WorkingDirectory="INSTALLFOLDER"
        Target="[INSTALLFOLDER]T3CHNRD'S Windows Tool Kit.exe" />
      <Shortcut
        Id="DesktopShortcut"
        Directory="DesktopFolder"
        Name="T3CHNRD'S Windows Tool Kit"
        WorkingDirectory="INSTALLFOLDER"
        Target="[INSTALLFOLDER]T3CHNRD'S Windows Tool Kit.exe" />
      <RemoveFolder Id="ProgramMenuDirRemove" Directory="ProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\T3CHNRDsWindowsToolKit" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Product>
</Wix>
